{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/leike0813/zotero-library-agent-bundle/schemas/evidence-bundle.schema.json",
  "title": "Zotero Library Agent Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "createdAt",
    "producer",
    "operation",
    "subjects",
    "artifacts",
    "writeback"
  ],
  "properties": {
    "schema": {
      "const": "zotero-library-agent.evidence-bundle.v1"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surfaceVersion", "cliVersion"],
      "properties": {
        "surfaceVersion": { "type": "string", "minLength": 1 },
        "cliVersion": { "type": "string", "minLength": 1 }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "command"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "subjects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "ref"],
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "ref": { "type": "object", "minProperties": 1 }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "mediaType", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "mediaType": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "workflow": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ownership", "workflowRunId"],
          "properties": {
            "ownership": { "const": "host-owned" },
            "workflowRunId": { "type": "string", "minLength": 1 },
            "skillRunIds": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ownership", "agentRunId", "agentRequestIds"],
          "properties": {
            "ownership": { "const": "agent-owned" },
            "agentRunId": { "type": "string", "minLength": 1 },
            "agentRequestIds": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "writeback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {
          "enum": [
            "not-requested",
            "pending-approval",
            "applied",
            "denied",
            "failed"
          ]
        },
        "targets": {
          "type": "array",
          "items": { "type": "object", "minProperties": 1 }
        }
      }
    }
  }
}
