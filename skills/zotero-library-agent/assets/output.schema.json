{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "canceled", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_file": {
      "type": "string",
      "minLength": 1,
      "description": "Path to a validated Zotero Library Agent evidence bundle.",
      "x-type": "artifact",
      "x-role": "evidence"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
